# Copiar a .env y ajustar valores. Las variables se prefijan con SALESCAT_.
SALESCAT_ENVIRONMENT=development

# Database — usar el host "db" cuando corre por docker compose, "localhost" si corre fuera
SALESCAT_DATABASE_URL=postgresql+asyncpg://salescat:salescat@localhost:5432/salescat

# Redis — cola de jobs y caché
SALESCAT_REDIS_URL=redis://localhost:6379/0

# LLM provider
SALESCAT_LLM_PROVIDER=mock
# SALESCAT_LLM_MODEL=llama-3.3-70b-versatile
# SALESCAT_LLM_API_KEY=
